// AIMarket Pro — local dev schema (SQLite). Swap `sqlite` → `postgresql` for prod.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  fbUserId  String   @unique
  email     String?
  name      String
  avatarUrl String?

  metaCredential  MetaCredential?
  byokKeys        ByokKey?
  preferences     Preferences?
  igPosts         IgPost[]
  snapshots       AnalyticsSnapshot[]
  campaigns       Campaign[]
  leads           Lead[]
  recommendations Recommendation[]
  notifications   Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MetaCredential {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // long-lived user access token (encrypted)
  accessToken String
  scopes      String

  // resolved after first login (Phase 2)
  pageId              String?
  pageName            String?
  pageAccessToken     String? // encrypted
  igBusinessAccountId String?
  igUsername          String?
  lastSyncedAt        DateTime?

  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ByokKey {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // all encrypted at rest
  anthropicKey      String?
  falKey            String?
  cloudflareToken   String?
  cloudflareAccount String?
  hfToken           String?
  groqKey           String?
  geminiKey         String?
  resendKey         String?
  newsApiKey        String?
  igToken           String?
  igUserId          String?

  updatedAt DateTime @updatedAt
}

model Preferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  optimizationMode String  @default("manual")
  alertBudget      Boolean @default(true)
  alertPerformance Boolean @default(true)
  alertScale       Boolean @default(true)

  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

// Hourly snapshot of account-level IG metrics. Lets us show trends without
// re-hitting the Graph API every page load, and gives a history for charts.
model AnalyticsSnapshot {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  igBusinessId String
  takenAt      DateTime @default(now())

  // JSON: { followers_count, follows_count, media_count, reach, impressions, profile_views, ... }
  accountMetrics String

  // JSON: optional audience breakdown (country, age_gender) — populated when available
  audienceMetrics String?

  @@index([userId, takenAt])
}

// Cached per-post data + insights. Refreshed by /api/instagram/sync.
model IgPost {
  id     String @id // IG media ID
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  caption       String?
  mediaType     String  // IMAGE | VIDEO | CAROUSEL_ALBUM | REELS
  mediaUrl      String?
  permalink     String?
  thumbnailUrl  String?
  timestamp     DateTime
  likeCount     Int     @default(0)
  commentsCount Int     @default(0)

  // JSON: per-post insights (engagement, reach, impressions, saved, video_views, ...)
  insightsJson String?
  insightsAt   DateTime?

  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments IgComment[]

  @@index([userId, timestamp])
}

// Cached comments for posts. Phase 3 will add per-comment sentiment in a
// separate IgCommentAnalysis table so we can re-classify without re-fetching.
model IgComment {
  id     String @id // IG comment ID
  postId String
  post   IgPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  text      String
  username  String?
  timestamp DateTime
  likeCount Int     @default(0)

  fetchedAt DateTime @default(now())

  analysis IgCommentAnalysis?

  @@index([postId, timestamp])
}

// ─── Phase 3: Campaigns, Leads, ML, Notifications, Trends ────────────────────

model Campaign {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  status      String   @default("draft") // draft | active | paused | archived
  product     String?
  description String?
  goals       String? // JSON array
  platforms   String? // JSON array: ["facebook", "instagram"]
  dailyBudget Float?
  lifetimeCap Float?
  targeting   String? // JSON
  copy        String? // JSON: { headline, body, cta }
  imageUrls   String? // JSON array
  videoUrl    String?
  estRevenue  Float? // user-entered revenue per conversion
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  metrics         CampaignMetric[]
  recommendations Recommendation[]
  leads           Lead[]

  @@index([userId, createdAt])
}

model CampaignMetric {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  date        DateTime
  impressions Int      @default(0)
  reach       Int      @default(0)
  clicks      Int      @default(0)
  leads       Int      @default(0)
  spend       Float    @default(0)
  revenue     Float    @default(0)

  @@unique([campaignId, date])
  @@index([campaignId, date])
}

model Lead {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  fullName    String
  email       String
  phone       String?
  productId   String?
  source      String?
  status      String    @default("new") // new | engaged | converted | lost
  estValue    Float?
  audienceTag String?
  score       Float? // ML lookalike score 0-1
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
}

model IgCommentAnalysis {
  id         String    @id @default(cuid())
  commentId  String    @unique
  comment    IgComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  sentiment  String // positive | neutral | negative | question
  intent     String? // praise | complaint | question | spam | other
  confidence Float
  analyzedAt DateTime  @default(now())
}

model Recommendation {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  type        String // anomaly | besttime | hashtag | budget | content | scaleup | forecast
  severity    String    @default("info") // info | warn | critical
  title       String
  message     String
  data        String? // JSON
  appliedAt   DateTime?
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // alert | info | success
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

model Trend {
  id        String   @id @default(cuid())
  source    String // ad_library | reddit | google | tiktok | news
  topic     String
  payload   String // JSON
  fetchedAt DateTime @default(now())

  @@index([source, fetchedAt])
}
