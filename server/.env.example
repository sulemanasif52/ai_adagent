# Copy this file to `.env` and fill in.
# AI keys are NOT here — users paste those in the Settings UI (BYOK).

# --- App-level secrets (must be in env, can't be in UI) ---
META_APP_ID=
META_APP_SECRET=

# --- Local dev infrastructure ---
DATABASE_URL="file:./dev.db"
PORT=3000
NODE_ENV=development

# --- Cookie + crypto secrets ---
# Run once: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
SESSION_SECRET=
ENCRYPTION_KEY=

# --- URLs ---
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
