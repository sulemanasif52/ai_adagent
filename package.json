{
  "name": "aimarket-pro-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server:install": "cd server && npm install",
    "server:migrate": "cd server && npx prisma migrate deploy",
    "server:generate": "cd server && npx prisma generate",
    "server:start": "cd server && node src/index.js",
    "build:all": "npm install && npm run build && npm run server:install && npm run server:generate",
    "start:prod": "npm run server:migrate && npm run server:start"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3",
    "lucide-react": "^0.363.0",
    "recharts": "^2.12.3",
    "framer-motion": "^11.0.24"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "vite": "^5.2.0"
  }
}
